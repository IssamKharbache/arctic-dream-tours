generator client {
    provider = "prisma-client-js"
    output   = "../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id              String   @id @default(uuid()) @db.Uuid
    email           String   @unique
    password        String
    createdAt       DateTime @default(now())
    isEmailVerified Boolean  @default(false)
    role            Role     @default(USER)
    updatedAt       DateTime @updatedAt
    firstName       String
    lastName        String
}

model EmailVerification {
    id        String   @id @default(uuid())
    email     String   @unique
    code      String
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@index([email])
}

model Activity {
    id                 String             @id @default(uuid()) @db.Uuid
    title              String
    slug               String             @unique
    description        String
    shortDescription   String
    cancellationPolicy String?
    included           String[]
    difficulty         ActivityDifficulty
    bring              String?
    tags               String[]
    duration           String
    meetingPoints      String[]
    bookingCutoffHours Int?
    liveTourGuide      Boolean
    location           String
    adultPrice         Float
    childPrice         Float
    privateTourPrice   Float
    
    imageUrl           String
    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt
    imageKey           String
    seasonType         SeasonType
    startDate          DateTime
    endDate            DateTime



    departureHours String[]
    booking       Booking[]
}

model Booking {
    id         String   @id @default(uuid()) @db.Uuid
    activityId String   @db.Uuid
    activity   Activity @relation(fields: [activityId], references: [id])
    date       DateTime
    adults     Int      @default(1)
    children   Int      @default(0)
    totalPrice Float
    bookingRef String @unique
    firstName  String
    lastName   String
    email      String
    phone      String
    departureHour String
    pickUpLocation String
    dropOffLocation String
    isPrivate Boolean @default(false)
    createdAt  DateTime @default(now())

    @@index([activityId])
    @@index([date])
}

enum Role {
    USER
    ADMIN
    MODERATOR
}

enum ActivityDifficulty {
    EASY
    MODERATE
    HARD
    EXTREME
}

enum SeasonType {
    WINTER
    SUMMER
}
